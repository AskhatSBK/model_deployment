# ==========================================================
#              НАСТРОЙКИ МОДЕЛИ И API (VLLM)
# ==========================================================
HF_HOME=/data/models/huggingface
# 💡 ID модели на HuggingFace. vLLM сам найдет эту модель 
# в примонтированном кэше. Замените на нужную модель.
# ПРИМЕР: RedHatAI/Llama-4-Scout-17B-16E-Instruct-quantized.w4a16
MODEL_ID=RedHatAI/Llama-4-Scout-17B-16E-Instruct-quantized.w4a16

# Имя, под которым модель будет видна в API (served-model-name).
# ПРИМЕР: llama-4-scout-api
MODEL_NAME=llama4scout

# Токен HuggingFace. Обязателен для приватных или Gated моделей.
# Если не нужен, оставьте пустым.
HUGGING_FACE_HUB_TOKEN=

# === ПАРАМЕТРЫ ЗАПУСКА ===

# Максимальная длина контекста (в токенах), которую будет использовать vLLM.
MAX_MODEL_LEN=60000

# Тип данных весов. "auto" — рекомендуется (автоматически выберет bfloat16/float16).
DTYPE=auto


# ==========================================================
#              НАСТРОЙКИ GPU И СЕТИ
# ==========================================================

# ID видеокарт, которые будут использоваться.
# "0" — первая карта, "0,1" — две карты, "all" — все доступные.
GPU_DEVICE_IDS=0

# Количество GPU, на которые будет разбита модель (Tensor Parallelism). 
# Должно соответствовать количеству карт в GPU_DEVICE_IDS.
TENSOR_PARALLEL_SIZE=1

# Доля GPU-памяти (от 0.0 до 1.0), зарезервированная под KV-кэш. 
# 0.95 — стандартное значение. Если OOM, уменьшите до 0.90.
GPU_MEMORY_UTILIZATION=0.7

# Порт на хост-машине, через который будет доступен API.
PORT=8000
